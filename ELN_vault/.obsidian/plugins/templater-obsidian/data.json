{
  "command_timeout": 5,
  "templates_folder": "assets/templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "assets/javascript/templater",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "/",
      "template": "assets/templates/New Note.md"
    },
    {
      "folder": "Daily Notes",
      "template": "assets/templates/New Daily Note.md"
    },
    {
      "folder": "Meetings",
      "template": "assets/templates/New Meeting.md"
    },
    {
      "folder": "Experiment Series",
      "template": "assets/templates/New Experiment Series.md"
    },
    {
      "folder": "Experiment Runs",
      "template": "assets/templates/New Experiment Run.md"
    },
    {
      "folder": "Specimens",
      "template": "assets/templates/New Specimen.md"
    },
    {
      "folder": "Instrument Configurations",
      "template": "assets/templates/New Instrument Configuration.md"
    },
    {
      "folder": "Checklists/Startup",
      "template": "assets/templates/New Startup Checklist.md"
    },
    {
      "folder": "Checklists/Shutdown",
      "template": "assets/templates/New Shutdown Checklist.md"
    },
    {
      "folder": "Data Records",
      "template": "assets/templates/New Data Record.md"
    },
    {
      "folder": "Tasks",
      "template": "assets/templates/New Task List.md"
    },
    {
      "folder": "Contacts",
      "template": "assets/templates/New Contact.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "assets/templates/New Experiment Run.md",
    "assets/templates/New Experiment Series.md",
    "assets/templates/New Contact.md",
    "assets/templates/New Data Record.md",
    "assets/templates/New Instrument Configuration.md",
    "assets/templates/New Note.md",
    "assets/templates/New Shutdown Checklist.md",
    "assets/templates/New Specimen.md",
    "assets/templates/New Startup Checklist.md"
  ],
  "startup_templates": [
    "assets/templates/Startup Template.md"
  ],
  "enable_ribbon_icon": true
}